<?xml version="1.0" encoding="utf-8"?>
<!--
  OPTION B — "Native" integration under the `ngsign` id.
  The backend is clean (dedicated id), BUT the Angular front does not know `ngsign`:
  you must build a frontend component + recompile the SPA (see TECHNICAL_MANUAL.md §3).
  For an immediate UI integration without a rebuild, use the "iparapheur-slot" template
  instead.
-->
<root>
    <signatoryBookEnabled>ngsign</signatoryBookEnabled>
    <signatoryBook>
        <id>ngsign</id>
        <!-- === The ONLY 2 required external settings === -->
        <url>https://sandbox.ng-sign.com</url>
        <token>__YOUR_NGSIGN_API_TOKEN__</token>
        <!-- ============================================== -->
        <defaultMode>BY_MAIL</defaultMode>
        <defaultOtp>NONE</defaultOtp>
        <defaultSigType>CERTIFIED_TIMESTAMP</defaultSigType>
        <choosePosition>true</choosePosition>
        <defaultPage>1</defaultPage>
        <defaultXAxis>81</defaultXAxis>
        <defaultYAxis>44.28125</defaultYAxis>
        <signedStates>SIGNED,COMPLETED,FINISHED,VALIDATED,DONE</signedStates>
        <refusedStates>REFUSED,REJECTED,CANCELED,CANCELLED,EXPIRED</refusedStates>
    </signatoryBook>
</root>
